{
  "functionRoot": ".cloudbase/functions",
  "functions": [
    {
      "name": "powerfee-cron",
      "timeout": 30,
      "runtime": "Nodejs18.15",
      "memorySize": 256,
      "handler": "index.main",
      "installDependency": true,
      "ignore": [
        "node_modules",
        ".env",
        ".cache"
      ],
      "triggers": [
        {
          "name": "hourly-powerfee-check",
          "type": "timer",
          "config": "0 0 * * * * *"
        }
      ]
    }
  ]
}
